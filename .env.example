# Copy this file to .env.local on each development computer, then add the
# values from your Supabase and OpenWeather dashboards. Never commit .env.local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Production browser origin used by Supabase confirmation and reset emails.
# Use the current Vercel production URL until a custom domain is live.
NEXT_PUBLIC_SITE_URL=https://frontline-forecast-the-weather-desk.vercel.app
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=
OPENWEATHER_API_KEY=
